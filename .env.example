# SnapFort runtime environment.
# Copy to `.env` (never commit `.env`) and fill in real values before
# `docker run --env-file .env ...`.

# ----- Runtime -----
NODE_ENV=production
PORT=5000

# ----- Huawei RDS (Postgres) -----
HUAWEI_PGHOST=
HUAWEI_PGPORT=5432
HUAWEI_PGUSER=
HUAWEI_PGPASSWORD=
HUAWEI_PGDATABASE=
HUAWEI_PGSSLMODE=require
# Optional path *inside the container* to the RDS CA bundle, e.g. /app/certs/rds-ca.pem
HUAWEI_PGSSLROOTCERT=

# ----- Huawei OBS (Object Storage) -----
HUAWEI_OBS_AK=
HUAWEI_OBS_SK=
HUAWEI_OBS_BUCKET=
HUAWEI_OBS_ENDPOINT=

# ----- AI providers (Azure OpenAI is primary, OpenAI is fallback) -----
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
OPENAI_API_KEY=

# ----- Session -----
SESSION_SECRET=change-me-to-a-long-random-string
